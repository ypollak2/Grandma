# grandma — model backend configuration
# Copy to .env and fill in what you need.
# No .env needed at all if you use Claude Code subscription (the default).

# ── Backend selection ───────────────────────────────────────────────────────
# Set GRANDMA_MODEL_BACKEND to pick a provider explicitly.
# Grandma auto-detects from available API keys when this is unset.
#
# Supported values:
#   claude_cli          — Claude Code subscription via `claude -p -` (default, no key needed)
#   anthropic           — Anthropic SDK (requires ANTHROPIC_API_KEY)
#   openai              — OpenAI (requires OPENAI_API_KEY)
#   openai_compatible   — Any OpenAI-compatible endpoint (set GRANDMA_BASE_URL)
#   ollama              — Local Ollama (http://localhost:11434/v1, no key needed)
#   groq                — Groq (requires GROQ_API_KEY)
#   gemini              — Gemini via OpenAI-compat (requires GEMINI_API_KEY)
#   custom_command      — Arbitrary subprocess (set GRANDMA_MODEL_COMMAND)

# GRANDMA_MODEL_BACKEND=ollama

# ── Model names ─────────────────────────────────────────────────────────────
# GRANDMA_MODEL=llama3.1               # default mode model
# GRANDMA_DEEP_MODEL=deepseek-r1       # deep mode model (falls back to GRANDMA_MODEL)

# ── API keys ─────────────────────────────────────────────────────────────────
# GRANDMA_API_KEY=                     # overrides all provider-specific keys below
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GROQ_API_KEY=
# GEMINI_API_KEY=
# GOOGLE_API_KEY=                      # fallback for Gemini

# ── Base URL (for OpenAI-compatible providers) ───────────────────────────────
# GRANDMA_BASE_URL=http://localhost:11434/v1   # Ollama
# GRANDMA_BASE_URL=https://api.groq.com/openai/v1
# GRANDMA_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# ── Custom subprocess backend ────────────────────────────────────────────────
# Grandma sends the prompt on stdin; expects JSON response on stdout.
# GRANDMA_MODEL_COMMAND=ollama run llama3.1
# GRANDMA_DEEP_MODEL_COMMAND=ollama run deepseek-r1

# ── Examples ─────────────────────────────────────────────────────────────────
#
# Ollama (local, no key):
#   GRANDMA_MODEL_BACKEND=ollama
#   GRANDMA_MODEL=llama3.1
#   GRANDMA_DEEP_MODEL=deepseek-r1
#
# OpenAI:
#   GRANDMA_MODEL_BACKEND=openai
#   GRANDMA_MODEL=gpt-4o-mini
#   GRANDMA_DEEP_MODEL=gpt-4.1
#   OPENAI_API_KEY=sk-...
#
# Groq (fast inference):
#   GRANDMA_MODEL_BACKEND=groq
#   GRANDMA_MODEL=llama-3.1-8b-instant
#   GRANDMA_DEEP_MODEL=llama-3.3-70b-versatile
#   GROQ_API_KEY=gsk_...
#
# Gemini:
#   GRANDMA_MODEL_BACKEND=gemini
#   GRANDMA_MODEL=gemini-2.5-flash
#   GRANDMA_DEEP_MODEL=gemini-2.5-pro
#   GEMINI_API_KEY=AIza...
#
# Any OpenAI-compatible provider:
#   GRANDMA_MODEL_BACKEND=openai_compatible
#   GRANDMA_BASE_URL=https://your-provider.example.com/v1
#   GRANDMA_API_KEY=your-key
#   GRANDMA_MODEL=your-model-name
